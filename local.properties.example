## This is an example local.properties file.
## Copy this file to 'local.properties' and fill in your secrets.

# Location of the SDK (usually auto-generated by Android Studio)
# sdk.dir=/path/to/your/android/sdk

# Google Maps API Key
# Get one at: https://console.cloud.google.com/google/maps-apis/credentials
MAPS_API_KEY=YOUR_API_KEY_HERE
